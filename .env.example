# ---- Claude (used by brief(), summarize(), the eval harness, and Vapi's LLM) ----
ANTHROPIC_API_KEY is used by local brief(), summarize(), and eval. Vapi must be configured separately in the Vapi dashboard.

# Model overrides (optional — these are the defaults). E.g. set CALLER_MODEL to
# claude-haiku-4-5 for lower realtime latency.
CALLER_MODEL=claude-sonnet-4-6
HELPER_MODEL=claude-opus-4-8
PROSPECT_MODEL=claude-sonnet-4-6
JUDGE_MODEL=claude-opus-4-8

# ---- Vapi (managed voice platform) ----
VAPI_API_KEY=
# The Vapi phone number id that places the outbound call (buy/import one in the Vapi dashboard)
VAPI_PHONE_NUMBER_ID=
# Reuse an existing assistant instead of creating one each run (optional)
VAPI_ASSISTANT_ID=

# ---- Meeting / Google Calendar ----
# Where the discovery-call invite is organized from / who the prospect meets.
SALES_TEAM_EMAIL=team@harels.example
# Display + real timezone for proposed slots.
SLOT_TZ_LABEL=ET
SLOT_IANA_TZ=America/New_York
# Turn on real Google Calendar invites (otherwise bookings are reserved + pending).
GCAL_ENABLED=false
GCAL_CALENDAR_ID=primary
GCAL_CREDENTIALS_PATH=secrets/google_credentials.json
GCAL_TOKEN_PATH=secrets/google_token.json
GCAL_CREATE_MEET=true

# ---- Demo wiring ----
# The number Alex will call for the demo (your own phone), E.164 e.g. +14155550123
DEMO_CALL_NUMBER=
# Public URL where Vapi can reach the FastAPI webhook server (e.g. an ngrok https URL)
PUBLIC_WEBHOOK_URL=https://example.ngrok.app
# Optional shared secret. If set, it's sent to Vapi as server.secret and the
# webhook rejects any request whose x-vapi-secret header doesn't match.
WEBHOOK_SECRET=
